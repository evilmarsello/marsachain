PORT=8788
DATABASE_URL=postgres://marsa:marsa@127.0.0.1:5432/marsa_pool
READ_NODE_URL=http://127.0.0.1:8080
MINING_NODE_URL=http://127.0.0.1:8080

# Treasury private keys — server-only, never commit. Order: pool_id 0..4.
# Format: base64 Ed25519 secret (32 bytes), comma-separated.
# Public addresses are in seed data / fullnode OfficialPoolParams.
POOL_TREASURY_KEYS=

POOL_REWARD_MODE=pplnc
PPLNC_TARGET_WINDOW_SECONDS=3600
PPLNC_N_MIN=10000
PPLNC_RECALC_INTERVAL_SECONDS=300
PPLNC_RATE_EMA_ALPHA=0.2
POOL_FINALITY_BLOCKS=8
