# cp .env.example .env  (or: npm run setup:env)

VITE_TELEGRAM_VALIDATE_TARGET=http://127.0.0.1:8787

# Vite dev proxy targets (browser uses same-origin /fullnode, /mining, /api/pool)
VITE_FULLNODE_PROXY_TARGET=http://127.0.0.1:8080
VITE_MINING_PROXY_TARGET=http://127.0.0.1:8080
VITE_POOL_PROXY_TARGET=http://127.0.0.1:8788

VITE_DEV_PROXY_HINT=http://127.0.0.1:8080

# Production / nginx same-origin paths (see .env.production)
VITE_READ_NODE_BASE=/fullnode
VITE_MINING_NODE_BASE=/mining
VITE_POOL_API_BASE=/api/pool
