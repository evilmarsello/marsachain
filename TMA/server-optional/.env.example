# Bot token from BotFather — server only, not in the repo or browser
BOT_TOKEN=123456:ABC-DEF...

# HTTP server port
PORT=8787

# Allowed CORS origins (comma-separated). Vite dev default includes localhost:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Maximum auth_date age (seconds), replay protection
INIT_DATA_MAX_AGE_SEC=86400
