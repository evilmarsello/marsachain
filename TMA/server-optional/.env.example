# Токен бота из BotFather — только на сервере, не в репозитории и не в браузере
BOT_TOKEN=123456:ABC-DEF...

# Порт HTTP-сервера
PORT=8787

# Разрешённые Origin для CORS (через запятую). Для Vite dev по умолчанию localhost:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Максимальный возраст auth_date (секунды), защита от replay
INIT_DATA_MAX_AGE_SEC=86400
