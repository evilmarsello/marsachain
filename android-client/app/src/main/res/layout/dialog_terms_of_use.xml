<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1C1C1E"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvTermsDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:text="@string/onboarding_terms_dialog_title" />

    <ScrollView
        android:id="@+id/termsScroll"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="12dp"
        android:fadeScrollbars="false"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarSize="6dp"
        android:paddingRight="10dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb_terms"
        android:scrollbarTrackVertical="@drawable/scrollbar_track_terms"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvTermsDialogBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="4dp"
            android:textColor="#AEAEB2"
            android:textSize="14sp"
            tools:text="Terms body loaded from res/raw/terms_of_use.txt" />
    </ScrollView>

    <TextView
        android:id="@+id/tvTermsDialogFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif"
        android:lineSpacingExtra="2dp"
        android:text="@string/onboarding_terms_footer_acknowledge"
        android:textColor="#8E8E93"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/btnTermsAccept"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/primary_button_background"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif-medium"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="@string/onboarding_terms_accept_button"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />
</LinearLayout>
