<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create MINER_STAKE"
        android:textSize="26sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/tvBalanceInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Wallet Balance: 0 MRS"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minimum stake: 100 MRS"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount to Stake (MRS)"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#8E8E93"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center"/>

    <EditText
        android:id="@+id/etStakeAmount"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginBottom="20dp"
        android:inputType="numberDecimal"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#636366"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:hint="Enter amount (e.g., 100-)" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You will receive mining credits based on your stake"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Credits refill every 100 blocks"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="10dp"
        android:layout_gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coins will be locked until unlock block"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="24dp"
        android:layout_gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Cancel"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:background="@drawable/secondary_button_background" />

        <Button
            android:id="@+id/btnCreateStake"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Create Stake"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:background="@drawable/send_button_background" />

    </LinearLayout>

</LinearLayout>
