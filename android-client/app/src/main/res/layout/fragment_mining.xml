<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin">

        <!-- Balance and Difficulty Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <!-- Balance Section (Left) -->
            <LinearLayout
                android:layout_width="68dp"
                android:layout_height="57dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/mining_total_balance"
                    android:textColor="#8E8E93"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:gravity="bottom|center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/balanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/balance_text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="sans-serif-light"
                        android:text="MRS"
                        android:textColor="#FFFFFF"
                        android:textSize="12dp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Network Info Section (Right) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/mining_total_blocks"
                        android:textColor="#8E8E93"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/networkHeightText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:fontFamily="sans-serif-light"
                        android:text="..."
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Active Miners -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/mining_active_miners"
                        android:textColor="#8E8E93"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/activeMininersText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:fontFamily="sans-serif-light"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Difficulty -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/mining_difficulty"
                        android:textColor="#8E8E93"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/difficultyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:fontFamily="sans-serif-light"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- MINER_STAKE Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <!-- Miner Stake Status -->
            <TextView
                android:id="@+id/minerStakeStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/mining_stake_lab"
                android:textColor="#8E8E93"
                android:textSize="11sp" />

            <!-- Cost per 1 credit (1 hash) - only when stake is active -->
            <TextView
                android:id="@+id/minerStakeCostPerCreditText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-medium"
                android:text=""
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:visibility="gone" />

            <!-- Unlock Block (only shown when stake is active) -->
            <TextView
                android:id="@+id/minerStakeUnlockText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text=""
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        
        <FrameLayout
            android:layout_width="@dimen/mining_glow_size"
            android:layout_height="@dimen/mining_glow_size"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin">

            <!-- Glow Effect Background -->

            
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/mining_glow_background" />

            <com.marsa.chain.ui.CircularProgressRingView
                android:id="@+id/miningProgressRing"
                android:layout_width="@dimen/mining_button_size"
                android:layout_height="@dimen/mining_button_size"
                android:layout_gravity="center"
                android:visibility="gone" />

            <com.marsa.chain.ui.MiningCoinView
                android:id="@+id/miningCoinView"
                android:layout_width="@dimen/mining_button_size"
                android:layout_height="@dimen/mining_button_size"
                android:layout_gravity="center" />

            <!-- Dim only the coin — overlay text/buttons stay bright (above this layer) -->
            <View
                android:id="@+id/miningButtonDimOverlay"
                android:layout_width="@dimen/mining_button_size"
                android:layout_height="@dimen/mining_button_size"
                android:layout_gravity="center"
                android:background="#80000000"
                android:visibility="gone" />

            <!-- Overlay message on coin (TMA style) -->
            <Button
                android:id="@+id/miningOverlayMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/create_stake_button_background"
                android:gravity="center"
                android:maxWidth="220dp"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:textColor="@color/primary_color"
                android:textSize="12sp"
                android:visibility="gone"
                app:backgroundTint="@null" />

            
            <Button
                android:id="@+id/createMinerStakeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/create_stake_button_background"
                android:paddingStart="32dp"
                android:paddingTop="16dp"
                android:paddingEnd="32dp"
                android:paddingBottom="16dp"
                android:text="@string/mining_create_stake_btn"
                android:textColor="@color/primary_color"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null" />

        </FrameLayout>

        
        <TextView
            android:id="@+id/miningCreditsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/mining_credits_na"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/miningBlockRateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Credits refill hint below coin (only when stake active, credits exhausted) -->
        <TextView
            android:id="@+id/creditsRefillText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Pool / Solo mode toggle (TMA-style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/miningModePoolLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/mining_mode_pool"
                android:textColor="#8E8E93"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/miningModeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/mining_mode_switch_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:id="@+id/miningModePoolIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.45"
                    android:contentDescription="@null"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_pool" />

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/mining_mode_track_bg">

                    <View
                        android:id="@+id/miningModeKnob"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="3dp"
                        android:background="@drawable/mining_mode_knob_bg" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/miningModeSoloIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:alpha="0.45"
                    android:contentDescription="@null"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/person" />
            </LinearLayout>

            <TextView
                android:id="@+id/miningModeSoloLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/mining_mode_solo"
                android:textColor="#8E8E93"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
