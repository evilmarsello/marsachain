<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:elevation="12dp"
    android:orientation="vertical">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="8dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        app:srcCompat="@drawable/ic_cloud_pointer" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-1dp"
        android:background="@drawable/cloud_popup_background"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/cloudTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/cloudMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="3dp"
            android:textColor="#D1D1D6"
            android:textSize="14sp"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/cloudButtonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cloudButtonNegative"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AEAEB2"
                app:rippleColor="#40FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cloudButtonPositive"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF9500"
                app:rippleColor="#40FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
