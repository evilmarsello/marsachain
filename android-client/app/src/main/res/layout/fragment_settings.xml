<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/settingsBrandLogo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:src="@drawable/logo" />

            <ImageView
                android:id="@+id/settingsBrandLogoname"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:src="@drawable/logoname" />
        </LinearLayout>

        <!-- Language (TMA: label left, compact picker right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin"
            android:background="@drawable/card_background"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingStart="@dimen/card_padding"
            android:paddingEnd="6dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/language_title"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/settingsLocalePicker"
                layout="@layout/locale_picker_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Network -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_network"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/connectionsButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings_connections"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"
                android:background="@drawable/warning_button_background" />

        </LinearLayout>

        <!-- Mining Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_mining_stake"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_miner_unstake_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="#8E8E93"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/minerUnstakeButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings_miner_unstake"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:enabled="false"
                android:alpha="0.45"
                android:background="@drawable/warning_button_background" />

        </LinearLayout>

        <!-- App Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_information"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/aboutButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="@string/settings_info_about_app"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/aboutMarsaChainButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="@string/settings_info_about_marsa"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/networkConfigButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="@string/settings_info_network_config"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/socialMediaButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="@string/settings_info_social_media"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background" />

            </LinearLayout>

        </LinearLayout>

        <!-- No Saved Wallets Message -->
        <TextView
            android:id="@+id/noSavedWalletsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_no_wallets"
            android:textSize="15sp"
            android:fontFamily="sans-serif"
            android:textColor="#8E8E93"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone" />


        <!-- Exit wallet -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <Button
                android:id="@+id/resetWalletFromPhraseButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/wallet_action_button"
                android:fontFamily="sans-serif-medium"
                android:text="@string/settings_exit_wallet"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/settingsAppVersionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="end"
            android:paddingTop="12dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp"
            android:textColor="#6C6C70"
            android:textSize="11sp" />

    </LinearLayout>

</ScrollView>
