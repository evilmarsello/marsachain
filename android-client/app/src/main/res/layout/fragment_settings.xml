<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin">

        <!-- Network -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/connectionsButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Connections"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"
                android:background="@drawable/warning_button_background" />

        </LinearLayout>

        <!-- Mining Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mining stake"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The minimum duration of a MINER_STAKE is 10,000 blocks."
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="#8E8E93"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/minerUnstakeButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="End mining stake (MINER_UNSTAKE)"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:enabled="false"
                android:alpha="0.45"
                android:background="@drawable/warning_button_background" />

        </LinearLayout>

        <!-- Wallet recovery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <Button
                android:id="@+id/resetWalletFromPhraseButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Exit from wallet"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:background="@drawable/wallet_action_button" />
        </LinearLayout>

        <!-- App Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Information"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/aboutButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="About App"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/aboutMarsaChainButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="About Marsa"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/secondary_button_background" />

            </LinearLayout>

        </LinearLayout>

        <!-- No Saved Wallets Message -->
        <TextView
            android:id="@+id/noSavedWalletsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No saved wallets found"
            android:textSize="15sp"
            android:fontFamily="sans-serif"
            android:textColor="#8E8E93"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">


                <ImageView
                    android:id="@+id/settingsBrandLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginRight="8dp"
                    android:adjustViewBounds="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="@null"
                    android:src="@drawable/logo" />


                <ImageView
                    android:id="@+id/settingsBrandLogoname"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="@null"
                    android:src="@drawable/logoname" />
        </LinearLayout>

        <TextView
            android:id="@+id/settingsAppVersionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="end"
            android:paddingTop="12dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp"
            android:textColor="#6C6C70"
            android:textSize="11sp" />

    </LinearLayout>

</ScrollView>
