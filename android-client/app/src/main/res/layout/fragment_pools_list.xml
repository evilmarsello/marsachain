<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/pools_intro"
            android:textColor="#8E8E93"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/poolsListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/poolsLoadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/common_loading"
            android:textColor="#8E8E93"
            android:visibility="gone" />

        <TextView
            android:id="@+id/poolsErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:textColor="#FF6B6B"
            android:visibility="gone" />

        <Button
            android:id="@+id/poolsInfoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/pools_info_button_background"
            android:fontFamily="sans-serif-medium"
            android:minHeight="44dp"
            android:paddingVertical="10dp"
            android:text="@string/pools_info_btn"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
