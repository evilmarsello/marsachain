<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IP Address"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#8E8E93"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/ipEditText"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:hint="Enter host/domain (optionally host:port)"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:textColor="#FFFFFF"
        android:textColorHint="#636366"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:inputType="text"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use host/IP or domain (without port)"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Cancel"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:background="@drawable/secondary_button_background" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Add"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:background="@drawable/send_button_background" />

    </LinearLayout>

    <Button
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="12dp"
        android:text="Delete Server"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#FFFFFF"
        android:background="@drawable/danger_button_background"
        android:visibility="gone" />

</LinearLayout>

