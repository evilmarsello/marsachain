<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔐 Private Key"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#8E8E93"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- Wallet Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/walletNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main Wallet"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/walletAddressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="mrs1234567890abcdef..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#8E8E93" />

    </LinearLayout>

    <!-- Private Key -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Private Key (keep it secret!):"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:textColor="#8E8E93"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press and hold to reveal"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:textColor="#636366"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/private_key_background"
        android:padding="12dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/privateKeyText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="mrs1234567890abcdef..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:maxLines="3"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/copyButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_copy"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Copy" />

    </LinearLayout>

    <!-- Warning -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/warning_background"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="16sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Never share your private key with anyone!"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:textColor="#FF9500" />

    </LinearLayout>

</LinearLayout>
