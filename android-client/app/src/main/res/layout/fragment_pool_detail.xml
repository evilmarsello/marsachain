<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin">

        <TextView
            android:id="@+id/poolDetailStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/poolStatsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/pool_detail_section_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:text="@string/pool_detail_pool_stats"
                android:textAllCaps="true"
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/poolStatsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/poolDetailWindowFill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/poolDetailParticipationHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/pool_mining_participation_hint"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/poolDetailFinderMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:textColor="#8E8E93"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/poolMinerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/pool_detail_miner_section_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:text="@string/pool_detail_your_stats"
                android:textAllCaps="true"
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/poolMinerShareHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:text="@string/pool_share_hint"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/poolMinerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/poolMinerNotInPool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/pool_not_in_this_pool"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/poolBalanceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/pool_detail_balance_card_bg"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/pool_available_to_withdraw"
                    android:textColor="#8E8E93"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/poolBalanceValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FF9500"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/poolBalanceSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif"
                    android:textColor="#8E8E93"
                    android:textSize="11sp" />

            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/poolJoinButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/pool_join_button_background"
            android:text="@string/pools_join_mining_pool"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:id="@+id/poolDetailFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="14dp"
                android:background="#1FFFFFFF" />

            <Button
                android:id="@+id/poolWithdrawButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/primary_button_background"
                android:text="@string/pools_withdraw_btn"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/poolWithdrawHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:textColor="#8E8E93"
                android:textSize="11sp" />

            <Button
                android:id="@+id/poolLeaveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/card_background"
                android:text="@string/pool_finish_unstake_btn"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/poolUnstakeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:textColor="#8E8E93"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
