<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/margin">

        <!-- Left Column - Balance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="@dimen/margin">

            <!-- Balance Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Total Balance"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#8E8E93"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/balanceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="@dimen/balance_text"
                    android:fontFamily="sans-serif-light"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </LinearLayout>

        <!-- Right Column - Mining -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⛏️ Mining"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/difficultyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty: ..."
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:textColor="#8E8E93"
                android:layout_marginBottom="28dp" />

            <!-- Circular Mining Button with Glow Effect -->
            <FrameLayout
                android:layout_width="@dimen/mining_glow_size"
                android:layout_height="@dimen/mining_glow_size"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/margin">

                <!-- Glow Effect Background -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/mining_glow_background" />

                <com.marsa.chain.ui.CircularProgressRingView
                    android:id="@+id/miningProgressRing"
                    android:layout_width="@dimen/mining_button_size"
                    android:layout_height="@dimen/mining_button_size"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <!-- Main Mining Button -->
                <Button
                    android:id="@+id/miningButton"
                    android:layout_width="@dimen/mining_button_size"
                    android:layout_height="@dimen/mining_button_size"
                    android:layout_gravity="center"
                    android:background="@drawable/circular_mining_button"
                    android:text="MRS"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/mining_button_text"
                    android:textStyle="bold" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
