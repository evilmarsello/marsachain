<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#44000000" />
        </shape>
    </item>
    <!-- Main circle with gradient (симметричные inset — центр круга = центр кнопки, иначе свечение «уезжает» вправо-вниз) -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#2C2C2E"
                android:centerColor="#1C1C1E"
                android:endColor="#0A0A0A"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#3A3A3C" />
        </shape>
    </item>
</layer-list>
